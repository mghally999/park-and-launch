# Server
NODE_ENV=development
PORT=3001
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/park_and_launch

# JWT
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_minimum_32_chars
JWT_REFRESH_EXPIRE=30d

# Cookie
COOKIE_EXPIRE=7

# Client URL
CLIENT_URL=http://localhost:3000

# Stripe (UAE PayTabs fallback)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Twilio (OTP SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+971XXXXXXXXX

# Email (Nodemailer / SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=noreply@parkandlaunch.ae
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@parkandlaunch.ae
FROM_NAME=Park & Launch

# AWS S3 (Media Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_BUCKET_NAME=park-and-launch-media
AWS_REGION=me-south-1

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key

# OpenWeather API (Free tier - 60 calls/min)
OPENWEATHER_API_KEY=your_openweather_key

# WorldTides API (Tide data)
WORLDTIDES_API_KEY=your_worldtides_key

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=park-and-launch
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@park-and-launch.iam.gserviceaccount.com

# Encryption
ENCRYPTION_KEY=32_char_encryption_key_for_data

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Camera Feed (Marine Yard CCTV API Placeholder)
CAMERA_API_BASE_URL=https://cameras.parkandlaunch.ae/api
CAMERA_API_KEY=your_camera_api_key
